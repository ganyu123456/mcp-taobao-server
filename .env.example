# ---- 运行镜像（离线部署时取消注释并指向本地或 Harbor 镜像）----
# MCP_IMAGE=harbor.zkjgy.online/library/mcp-taobao-server:latest
# docker load -i mcp-taobao-server_v2.0.0_linux-amd64.tar.gz
# MCP_IMAGE=mcp-taobao-server:v2.0.0

MCP_PORT=8094
MCP_TRANSPORT=sse

# ============================================================
# 淘宝闪购 / 饿了么外卖（Playwright + Xvfb 虚拟有头）
# ------------------------------------------------------------
# 部署在【无物理屏幕的 Linux 服务器】上，容器内用 Xvfb 提供虚拟显示，让 Chromium 以
# 【有头】方式运行（比 headless 更不易被饿了么风控识别）。登录态保存在 profile 目录，
# 但饿了么登录态是【会话级】——服务进程存活期间有效，进程重启需重新登录。
#
# 人工介入流程（服务器场景，都在 noVNC 里做）：
#   1) 调 shangou_open_login → 浏览器打开 http://<服务器IP>:6080/vnc.html
#      在窗口里：输入手机号 → 短信验证码 → 拖滑块 → 同意协议并登录
#   2) shangou_list_addresses / shangou_set_address 选收货地址
#   3) shangou_search 搜附近店 → shangou_shop_menu → shangou_add_to_cart 加购
#   4) shangou_create_order → 走到确认订单/支付页即停，返回金额+截图
#   5) 回到 noVNC 窗口【手动确认并支付】
# ============================================================

# 浏览器持久化 profile 目录（容器内挂卷持久化）
MCP_TAOBAO_USER_DATA_DIR=/data/profile

# 有头 or 无头。配合 Xvfb 用 false（有头，推荐）
MCP_TAOBAO_HEADLESS=false

# 默认定位（经纬度）——决定“附近”门店范围；选定收货地址后以地址为准。
# 示例为南京；改成你的城市坐标。
MCP_TAOBAO_LAT=32.06
MCP_TAOBAO_LNG=118.80

# 页面操作超时（秒）
MCP_TAOBAO_TIMEOUT=30

# 搜索/菜单返回条数上限
MCP_TAOBAO_MAX_RESULTS=10

# ---- 安全护栏 ----
# 生成订单金额上限（元）。确认页金额超过此值则拒绝提交并提示，防误单。0 表示不限制。
MCP_TAOBAO_MAX_ORDER_AMOUNT=100
# Playwright 每步操作放慢（毫秒），便于观察/降低风控，0=不放慢
MCP_TAOBAO_SLOWMO=0

# ---- Xvfb / noVNC（由容器 entrypoint 使用；本地有真实显示器可忽略）----
DISPLAY=:99
MCP_TAOBAO_SCREEN=1280x1024x24
MCP_TAOBAO_NOVNC_PORT=6080
# VNC 访问密码（留空则无密码，仅建议放内网/反向代理后）
MCP_TAOBAO_VNC_PASSWORD=

MCP_VERSION=latest
