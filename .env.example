# ---- 运行镜像（离线部署时取消注释并指向本地或 Harbor 镜像）----
# MCP_IMAGE=harbor.zkjgy.online/library/mcp-taobao-server:latest
# docker load -i mcp-taobao-server_v1.0.0_linux-amd64.tar.gz
# MCP_IMAGE=mcp-taobao-server:v1.0.0

MCP_PORT=8094
MCP_TRANSPORT=sse

# ============================================================
# 淘宝浏览器自动化（Playwright + Xvfb 虚拟有头）
# ------------------------------------------------------------
# 本 server 部署在【无物理屏幕的 Linux 服务器】上，容器内用 Xvfb 提供一块
# 虚拟显示，让 Chromium 以【有头】方式运行（比 headless 更不易被淘宝风控识别）。
# 登录态保存在 MCP_TAOBAO_USER_DATA_DIR，扫码登录一次可长期复用。
#
# 人工付款流程（服务器场景）：
#   1) 调 taobao_get_login_qrcode → 返回二维码 base64 → 手机淘宝 App 扫码登录
#   2) 调 taobao_search / taobao_add_to_cart 选货加购
#   3) 调 taobao_create_order → 走到“确认订单/支付页”即停，返回金额摘要 + 截图
#   4) 浏览器打开  http://<服务器IP>:6080/  （noVNC）接管虚拟桌面，
#      在 Chromium 里【手动点击提交并在支付宝页确认付款】
# ============================================================

# 浏览器持久化 profile 目录（保存 cookie/登录态；容器内挂卷持久化）
MCP_TAOBAO_USER_DATA_DIR=/data/profile

# 有头 or 无头。配合 Xvfb 用 false（有头，推荐）；纯查询可 true。
MCP_TAOBAO_HEADLESS=false

# 站点：h5=手机版 m.taobao.com（反爬较弱，推荐）；pc=taobao.com
MCP_TAOBAO_SITE=h5

# 页面操作超时（秒）
MCP_TAOBAO_TIMEOUT=30

# 搜索返回条数上限
MCP_TAOBAO_MAX_RESULTS=10

# ---- 安全护栏 ----
# 生成订单金额上限（元）。确认订单页金额超过此值则拒绝并提示，防误购。0 表示不限制。
MCP_TAOBAO_MAX_ORDER_AMOUNT=200
# 单次加购最大数量
MCP_TAOBAO_MAX_QTY=10
# Playwright 每步操作放慢（毫秒），便于观察/降低风控，0=不放慢
MCP_TAOBAO_SLOWMO=0

# ---- Xvfb / noVNC（由容器 entrypoint 使用；本地有真实显示器可忽略）----
# 虚拟显示编号，Chromium 有头模式使用
DISPLAY=:99
# 虚拟屏分辨率
MCP_TAOBAO_SCREEN=1280x1024x24
# noVNC 网页端口（compose 暴露，用于远程接管手动付款）
MCP_TAOBAO_NOVNC_PORT=6080
# VNC 访问密码（留空则无密码，仅建议放内网/反向代理后）
MCP_TAOBAO_VNC_PASSWORD=

MCP_VERSION=latest
